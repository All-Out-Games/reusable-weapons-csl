{
  "permissions": {
    "allow": [
      "Edit",
      "Write",
      "AskUserQuestion",
      "Grep",
      "Glob",
      "TodoWrite",
      "Skill(*)",
      "Skill(abilities)",
      "Skill(client-specific-state)",
      "Skill(effects)",
      "Skill(format-strings)",
      "Skill(interactables)",
      "Skill(inventory)",
      "Skill(inventory-droppable-items)",
      "Skill(logging)",
      "Skill(navmeshes-and-collision)",
      "Skill(save)",
      "Skill(spine)",
      "Skill(syntax)",
      "Skill(uik)",
      "Skill(uik-cards)",
      "Skill(ui-world-and-overlays)",
      "Skill(game-design)",
      "mcp__allout__asset_local_search",
      "mcp__allout__spine_rig_info",
      "mcp__allout__compile",
      "mcp__allout__products_list"
    ]
  },
  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": [
    "allout"
  ]
,
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Read|Grep|Glob",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/block_asset_manifest_read.py\""
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/block_scene_write.py\""
          }
        ]
      }
    ]
  }
}